# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# MongoDB connection string.
# IMPORTANT: the previously committed credential (test-mongo.js) is compromised
# and must be rotated in MongoDB Atlas. Use the new one here.
MONGODB_URI=

# NextAuth session signing secret (REQUIRED — the app refuses to start without it).
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of the app.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (OPTIONAL — leave blank to disable Google sign-in).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin allowlist (comma-separated emails). There is no public admin signup;
# any user who signs in with one of these emails is promoted to the admin role.
# Example: ADMIN_EMAILS=you@example.com,co-admin@example.com
ADMIN_EMAILS=

# Super admin allowlist (comma-separated emails). Works like ADMIN_EMAILS but
# promotes to 'super_admin', which outranks 'admin' (e.g. only a super_admin
# can delete another super_admin's account).
# Example: SUPER_ADMIN_EMAILS=founder@example.com
SUPER_ADMIN_EMAILS=

# Direct download link for the Android app's built .apk (OPTIONAL — the
# homepage's "Also on Android" banner shows a "Coming soon" state until this
# is set). A GitHub Release asset URL is a good free host for this; do not
# commit the .apk itself into the repo. See MOBILE_APP.md Phase 4.
NEXT_PUBLIC_ANDROID_APK_URL=
