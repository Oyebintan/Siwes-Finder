# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# MongoDB connection string.
# IMPORTANT: the previously committed credential (test-mongo.js) is compromised
# and must be rotated in MongoDB Atlas. Use the new one here.
MONGODB_URI=

# NextAuth session signing secret (REQUIRED — the app refuses to start without it).
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of the app.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (OPTIONAL — leave blank to disable Google sign-in).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin allowlist (comma-separated emails). There is no public admin signup;
# any user who signs in with one of these emails is promoted to the admin role.
# Example: ADMIN_EMAILS=you@example.com,co-admin@example.com
ADMIN_EMAILS=

# Super admin allowlist (comma-separated emails). Works like ADMIN_EMAILS but
# promotes to 'super_admin', which outranks 'admin' (e.g. only a super_admin
# can delete another super_admin's account).
# Example: SUPER_ADMIN_EMAILS=founder@example.com
SUPER_ADMIN_EMAILS=

# Resend (email). Used for the forgot-password OTP flow and the
# notification emails (application decisions, logbook approvals,
# verification decisions). Notification emails are best-effort: if the key
# is unset or Resend is down, the underlying action still succeeds and the
# failure is only logged. RESEND_FROM_EMAIL is optional — defaults to
# Resend's shared onboarding@resend.dev sender, which works with no DNS
# setup; set it once a custom domain is verified on the Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Direct download link for the Android app's built .apk (OPTIONAL — the
# homepage's "Also on Android" banner shows a "Coming soon" state until this
# is set). A GitHub Release asset URL is a good free host for this; do not
# commit the .apk itself into the repo. See MOBILE_APP.md Phase 4.
NEXT_PUBLIC_ANDROID_APK_URL=

# Shared secret for POST /api/cron/logbook-streak-reminders (REQUIRED for
# that route to accept requests at all — it has no user session to check,
# since it's fired by a scheduled GitHub Action, not a logged-in user).
# Generate one with: openssl rand -hex 32
# Set the *same* value here as in the GitHub Actions repo secret
# CRON_SECRET — see .github/workflows/logbook-streak-reminders.yml.
CRON_SECRET=
