# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# MongoDB connection string.
# IMPORTANT: the previously committed credential (test-mongo.js) is compromised
# and must be rotated in MongoDB Atlas. Use the new one here.
MONGODB_URI=

# NextAuth session signing secret (REQUIRED — the app refuses to start without it).
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of the app.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (OPTIONAL — leave blank to disable Google sign-in).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
