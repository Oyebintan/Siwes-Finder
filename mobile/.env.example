# Copy to .env and fill in. EXPO_PUBLIC_-prefixed vars are inlined into the
# JS bundle at build time (Expo's convention) -- never put a secret here.

# The deployed API origin (the Next.js site). Production:
# EXPO_PUBLIC_API_URL=https://siwes-finder-eight.vercel.app
#
# Local dev against `npm run dev` in the repo root:
#   Android emulator: http://10.0.2.2:3000  (this is the default if unset)
#   iOS Simulator:    http://localhost:3000
#   Physical device:  http://<your-machine's-LAN-IP>:3000
EXPO_PUBLIC_API_URL=
