# Copy to .env and fill in. EXPO_PUBLIC_-prefixed vars are inlined into the
# JS bundle at build time (Expo's convention) -- never put a secret here.

# The deployed API origin (the Next.js site). Production:
# EXPO_PUBLIC_API_URL=https://siwes-finder-eight.vercel.app
#
# Local dev against `npm run dev` in the repo root:
#   Android emulator: http://10.0.2.2:3000  (this is the default if unset)
#   iOS Simulator:    http://localhost:3000
#   Physical device:  http://<your-machine's-LAN-IP>:3000
EXPO_PUBLIC_API_URL=

# Google sign-in (see api/googleAuth.ts). Optional -- the "Continue with
# Google" button on login/signup only renders once the client ID for the
# current platform is set, same as the web's GoogleProvider. Create these
# in Google Cloud Console > APIs & Services > Credentials:
#   - Android: an "Android" OAuth client, package name com.siwesfinder.app,
#     signed with the SHA-1 EAS uses for this build profile
#     (`eas credentials` -> Android -> Keystore).
#   - iOS: an "iOS" OAuth client, once this app ships on iOS.
#   - Web: reuse the existing web client ID (GOOGLE_CLIENT_ID in the
#     website's env) -- it also covers Expo Go / dev builds.
# The backend needs the matching GOOGLE_ANDROID_CLIENT_ID / GOOGLE_IOS_CLIENT_ID
# env vars (see src/app/api/mobile/google-signin/route.ts) to verify tokens
# issued for these client IDs.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
